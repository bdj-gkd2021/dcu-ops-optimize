+            asm volatile("v_pk_fma_f32 %0, %1, %2, %3" : "=v"(a) : "v"(a), "v"(float2{b, b}), "v"(float2{c, c}));
+            tensor(mi, ni) = a.x;
+            tensor(mi, ni + 4) = a.y;
+        }
+    }
