+__device__ __forceinline__ void fast_reduce_sum_f16_f32(Tensor<Engine0, Layout0> const& tensor, Tensor<Engine1, Layout1> &sum){
+    static_assert(Layout0::rank == 2, "Only support 2D Tensor");
